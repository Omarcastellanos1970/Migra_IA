  "idioma": "es",
  "descripcion": "Cuestionario maestro adaptativo para diagnostico de obsolescencia y migracion de sistemas de automatizacion industrial. El agente NO debe leerlo de forma rigida: las respuestas activan, ocultan o modifican las preguntas siguientes (principio de cuestionario adaptativo).",
  "secciones": [
    {
      "id": "A",
      "titulo": "Identificacion del usuario",
      "preguntas": [
        {"codigo": "A01", "texto": "Nombre del responsable del caso", "tipo": "texto", "obligatorio": true},
        {"codigo": "A02", "texto": "Cargo o funcion", "tipo": "seleccion", "opciones": ["Tecnico de mantenimiento", "Ingeniero de automatizacion", "Ingeniero electrico", "Supervisor de produccion", "Integrador de sistemas", "Estudiante o investigador", "Otro"]},
        {"codigo": "A03", "texto": "Nivel de experiencia en automatizacion", "tipo": "seleccion", "opciones": ["Basico", "Intermedio", "Avanzado", "Especialista"], "regla_adaptativa": "El nivel seleccionado determina la profundidad del lenguaje tecnico y la cantidad de explicaciones mostradas."},
        {"codigo": "A04", "texto": "Correo electronico", "tipo": "texto_validado"},
        {"codigo": "A05", "texto": "Telefono de contacto", "tipo": "texto", "obligatorio": false},
        {"codigo": "A06", "texto": "Pais", "tipo": "seleccion"},
        {"codigo": "A07", "texto": "Esta autorizado para acceder o modificar el sistema?", "tipo": "seleccion", "opciones": ["Si", "No", "Solo autorizado para diagnostico", "Pendiente de autorizacion"], "regla_adaptativa": "Si la respuesta es 'No', el agente puede ofrecer informacion general pero NO instrucciones operativas de modificacion."}
      ]
    },
    {
      "id": "B",
      "titulo": "Identificacion de la empresa y planta",
      "preguntas": [
        {"codigo": "B01", "texto": "Nombre de la empresa", "tipo": "texto"},
        {"codigo": "B02", "texto": "Nombre o codigo de la planta", "tipo": "texto"},
        {"codigo": "B03", "texto": "Sector industrial", "tipo": "seleccion", "opciones": ["Alimentos y bebidas", "Textil", "Plasticos", "Calzado", "Farmaceutico", "Mineria", "Energia", "Agua y saneamiento", "Manufactura", "Automotriz", "Cemento", "Quimico", "Otro"]},
        {"codigo": "B04", "texto": "Ubicacion general de la planta (ciudad, region y pais)", "tipo": "texto"},
        {"codigo": "B05", "texto": "La planta cuenta con normas o procedimientos internos para modificaciones?", "tipo": "seleccion", "opciones": ["Si", "No", "No se conoce"]},
        {"codigo": "B06", "texto": "Normas aplicables", "tipo": "seleccion_multiple", "opciones": ["IEC", "ISA", "IEEE", "NFPA", "NEC", "ISO", "Normativas locales", "Normas internas", "No se conoce"]}
      ]
    },
    {
      "id": "C",
      "titulo": "Identificacion de la maquina o proceso",
      "preguntas": [
        {"codigo": "C01", "texto": "Nombre de la maquina", "tipo": "texto"},
        {"codigo": "C02", "texto": "Codigo interno de la maquina", "tipo": "texto"},
        {"codigo": "C03", "texto": "Fabricante de la maquina", "tipo": "texto"},
        {"codigo": "C04", "texto": "Modelo de la maquina", "tipo": "texto"},
        {"codigo": "C05", "texto": "Ano aproximado de fabricacion", "tipo": "numero"},
        {"codigo": "C06", "texto": "Descripcion del proceso: que produce, que movimientos realiza, que variables controla, y que condiciones inician y detienen el ciclo", "tipo": "texto_extenso"},
        {"codigo": "C07", "texto": "Estado actual", "tipo": "seleccion", "opciones": ["Operando normalmente", "Operando con fallas", "Operacion intermitente", "Fuera de servicio", "Desmontada", "En modernizacion"]},
        {"codigo": "C08", "texto": "Criticidad de la maquina", "tipo": "seleccion", "opciones": ["Baja: puede detenerse varios dias", "Media: afecta parcialmente la produccion", "Alta: afecta una linea importante", "Critica: detiene la planta o presenta riesgo de seguridad"]},
        {"codigo": "C09", "texto": "Horas de operacion", "tipo": "seleccion", "opciones": ["Menos de 8 horas diarias", "Entre 8 y 16 horas", "Entre 16 y 24 horas", "Operacion continua"]},
        {"codigo": "C10", "texto": "Tiempo maximo permitido de parada", "tipo": "seleccion", "opciones": ["Menos de 1 hora", "1 a 4 horas", "4 a 12 horas", "12 a 24 horas", "Mas de 24 horas"]},
        {"codigo": "C11", "texto": "Se conoce con exactitud la logica de control programada en el PLC (como decide el sistema cada accion, condiciones e interbloqueos)?", "tipo": "seleccion", "opciones": ["Si, documentada y comprendida", "Si, parcialmente", "Solo se conoce el comportamiento externo", "No se conoce"], "regla_adaptativa": "Si la respuesta no es 'Si, documentada y comprendida', registrar dato faltante: sin conocer la logica de control, una migracion exige recuperar y analizar el programa (ingenieria inversa) antes de reconstruirlo, lo que aumenta el riesgo y el tiempo."},
        {"codigo": "C12", "texto": "Se conoce con exactitud la secuencia de operacion de la maquina (orden de pasos, condiciones de arranque, paro y emergencia, tiempos y enclavamientos)?", "tipo": "seleccion", "opciones": ["Si, documentada", "Si, por experiencia del personal", "Parcialmente", "No se conoce"], "regla_adaptativa": "Si no se conoce, priorizar el levantamiento de la secuencia (entrevistas al operador, observacion del ciclo y analisis del programa) antes de migrar; marcarla como dato faltante critico para las pruebas SAT."}
      ]
    },
    {
