        {"codigo": "D02", "texto": "Familia del PLC (dependiente del fabricante)", "tipo": "seleccion_dependiente", "opciones_por_fabricante": {"Siemens": ["S5", "S7-200", "S7-300", "S7-400", "S7-1200", "S7-1500"], "Mitsubishi": ["FX", "Q", "iQ-R"], "Rockwell Automation/Allen-Bradley": ["SLC 500", "MicroLogix", "CompactLogix", "ControlLogix"], "Schneider Electric": ["Modicon"], "Omron": ["CJ", "NJ", "NX"], "Otro": ["Otra"]}},
        {"codigo": "D03", "texto": "Modelo exacto de CPU", "tipo": "texto", "regla_adaptativa": "Si el usuario no conoce el modelo, solicitar fotografia de la placa."},
        {"codigo": "D04", "texto": "Numero de catalogo o referencia", "tipo": "texto"},
        {"codigo": "D05", "texto": "Numero de serie", "tipo": "texto", "obligatorio": false},
        {"codigo": "D06", "texto": "Version de firmware", "tipo": "texto"},
