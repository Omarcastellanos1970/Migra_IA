        {"codigo": "D08", "texto": "Estado de la CPU", "tipo": "seleccion", "opciones": ["RUN", "STOP", "FALLA", "Sin energia", "Desconocido"]},
        {"codigo": "D09", "texto": "La CPU posee indicadores de error?", "tipo": "seleccion", "opciones": ["Si", "No", "No verificado"], "regla_adaptativa": "Si responde 'Si', solicitar fotografia e identificacion de los LED activos."},
        {"codigo": "D10", "texto": "La CPU esta protegida con contrasena?", "tipo": "seleccion", "opciones": ["Si", "No", "No se conoce"]},
        {"codigo": "D11", "texto": "Existe una CPU de repuesto?", "tipo": "seleccion", "opciones": ["Si, nueva", "Si, usada", "No", "No se conoce"]},
        {"codigo": "D12", "texto": "Existen modulos de repuesto?", "tipo": "seleccion", "opciones": ["Si", "Parcialmente", "No", "No se conoce"]},
        {"codigo": "D13", "texto": "Cantidad total de entradas digitales (DI) del sistema", "tipo": "numero", "regla_adaptativa": "Conteo global usado para dimensionar la CPU y la periferia destino (Regla 6). Complementa el inventario detallado por modulo de la Seccion E. Si no se conoce con exactitud, pedir una estimacion y marcar dato faltante."},
        {"codigo": "D14", "texto": "Cantidad total de salidas digitales (DO) del sistema", "tipo": "numero", "regla_adaptativa": "Idem D13: dimensiona las salidas digitales de la plataforma destino y ayuda a estimar consumo y tipo de salida (rele, transistor, triac)."},
        {"codigo": "D15", "texto": "Cantidad total de entradas analogicas (AI) del sistema", "tipo": "numero", "regla_adaptativa": "Dimensiona los canales analogicos de entrada; anotar el tipo de senal (0-10 V, +-10 V, 4-20 mA, RTD/PT100, termopar) junto al conteo cuando se conozca."},
        {"codigo": "D16", "texto": "Cantidad total de salidas analogicas (AO) del sistema", "tipo": "numero", "regla_adaptativa": "Dimensiona los canales analogicos de salida; anotar el tipo de senal (0-10 V, +-10 V, 4-20 mA) cuando se conozca."}
      ]
